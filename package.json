{
  "name": "benyuan-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:staging:dry": "bash scripts/deploy-staging.sh --dry-run",
    "test:product:gate": "node scripts/benyuan-product-test-gate.mjs",
    "smoke:product:gate:contract": "node scripts/benyuan-product-test-gate-contract-smoke.mjs",
    "smoke:deploy:artifact": "node scripts/benyuan-deploy-artifact-smoke.mjs",
    "smoke:flow": "node --experimental-strip-types scripts/smoke-flow.mjs",
    "smoke:flow:deep": "BENYUAN_MODE=deep node --experimental-strip-types scripts/smoke-flow.mjs",
    "smoke:flow:all": "npm run smoke:flow && npm run smoke:flow:deep",
    "smoke:flow:hybrid": "BENYUAN_ANALYSIS_ENGINE=hybrid node --experimental-strip-types scripts/smoke-flow.mjs",
    "smoke:runtime:hybrid": "node --input-type=module -e \"const base=process.env.BENYUAN_BASE_URL??'http://localhost:3000'; const res=await fetch(base + '/api/analysis/runtime?mode=deep&engine=hybrid'); const data=await res.json(); if(!data.runtime.fallbackActive) throw new Error('expected fallback'); console.log(JSON.stringify(data.runtime));\"",
    "smoke:runtime:page": "node --input-type=module -e \"const base=process.env.BENYUAN_BASE_URL??'http://localhost:3000'; const res=await fetch(base + '/lab/runtime'); if(!res.ok) throw new Error('runtime page not reachable'); console.log('runtime-page:ok');\"",
    "smoke:runtime:gate": "node scripts/benyuan-runtime-gate-smoke.mjs",
    "smoke:processing:ui": "node scripts/benyuan-processing-ui-contract-smoke.mjs",
    "smoke:constellation:ui": "node scripts/benyuan-constellation-ui-contract-smoke.mjs",
    "smoke:theater:ui": "node scripts/benyuan-theater-ui-contract-smoke.mjs",
    "smoke:store:empty": "node scripts/benyuan-store-empty-smoke.mjs",
    "ios:shell:regression": "node scripts/benyuan-ios-regression.mjs",
    "ios:shell:build": "cd mobile/benyuan_origin_ios_shell && xcodegen generate && xcodebuild -project BenyuanOriginShell.xcodeproj -scheme BenyuanOriginShell -sdk iphonesimulator -destination \"platform=iOS Simulator,name=iPhone 17\" CODE_SIGNING_ALLOWED=NO build",
    "ios:shell:native-smoke": "node scripts/benyuan-ios-native-smoke.mjs",
    "smoke:benyuan:test-packs": "node scripts/benyuan-test-pack-audit.mjs",
    "smoke:benyuan:golden": "node scripts/benyuan-golden-audit.mjs",
    "smoke:benyuan:benchmark": "node scripts/benyuan-pack-benchmark.mjs",
    "lane:worktrees": "bash scripts/parallel-worktree.sh ensure benyuan",
    "lane:worktrees:status": "bash scripts/parallel-worktree.sh status benyuan",
    "lane:bootstrap": "bash scripts/parallel-bootstrap.sh benyuan",
    "lane:bootstrap:no-start": "PARALLEL_BOOTSTRAP_START=0 bash scripts/parallel-bootstrap.sh benyuan",
    "lane:stop": "bash scripts/parallel-lane.sh stop benyuan",
    "lane:status": "bash scripts/parallel-lane.sh status benyuan",
    "lane:benyuan:start": "bash scripts/parallel-lane.sh start benyuan",
    "lane:benyuan:stop": "bash scripts/parallel-lane.sh stop benyuan",
    "lane:benyuan:tail": "bash scripts/parallel-lane.sh tail benyuan",
    "lane:benyuan:prompt": "bash scripts/parallel-lane.sh prompt benyuan"
  },
  "dependencies": {
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@tailwindcss/postcss": "4.1.17",
    "@types/node": "24.10.1",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3"
  }
}
