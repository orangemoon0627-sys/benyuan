{
  "name": "benyuan-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:codex:companion": "npx --yes tsx --tsconfig tsconfig.json scripts/codex-companion.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "smoke:flow": "node --experimental-strip-types scripts/smoke-flow.mjs",
    "smoke:flow:deep": "BENYUAN_MODE=deep node --experimental-strip-types scripts/smoke-flow.mjs",
    "smoke:flow:all": "npm run smoke:flow && npm run smoke:flow:deep",
    "smoke:flow:hybrid": "BENYUAN_ANALYSIS_ENGINE=hybrid node --experimental-strip-types scripts/smoke-flow.mjs",
    "smoke:runtime:hybrid": "node --input-type=module -e \"const base=process.env.BENYUAN_BASE_URL??'http://localhost:3000'; const res=await fetch(base + '/api/analysis/runtime?mode=deep&engine=hybrid'); const data=await res.json(); if(!data.runtime.fallbackActive) throw new Error('expected fallback'); console.log(JSON.stringify(data.runtime));\"",
    "smoke:runtime:page": "node --input-type=module -e \"const base=process.env.BENYUAN_BASE_URL??'http://localhost:3000'; const res=await fetch(base + '/lab/runtime'); if(!res.ok) throw new Error('runtime page not reachable'); console.log('runtime-page:ok');\"",
    "smoke:tradewise": "node scripts/tradewise-smoke.mjs",
    "ios:shell:regression": "node scripts/benyuan-ios-regression.mjs",
    "ios:shell:build": "node scripts/benyuan-ios-shell-build.mjs",
    "ios:shell:archive": "node scripts/benyuan-ios-shell-archive.mjs",
    "ios:shell:testflight:preflight": "node scripts/benyuan-ios-testflight-preflight.mjs",
    "smoke:tradewise:anthropic": "node scripts/tradewise-anthropic-smoke.mjs",
    "smoke:tradewise:crs": "node scripts/tradewise-crs-smoke.mjs",
    "ios:shell:native-smoke": "node scripts/benyuan-ios-native-smoke.mjs",
    "smoke:tradewise:research": "node scripts/tradewise-research-smoke.mjs",
    "dev:tradewise:mock": "next dev --hostname 127.0.0.1 --port 3201",
    "dev:tradewise:crs": "TRADEWISE_REVIEW_PROVIDER=crs next dev --hostname 127.0.0.1 --port 3201",
    "smoke:tradewise:all": "node scripts/tradewise-all-smoke.mjs",
    "smoke:tradewise:research:remote": "node scripts/tradewise-research-remote-smoke.mjs",
    "dev:tradewise:remote": "bash scripts/tradewise-dev-remote.sh",
    "smoke:tradewise:remote:all": "node scripts/tradewise-remote-all-smoke.mjs",
    "smoke:tradewise:research:upstream": "npx --yes tsx --tsconfig tsconfig.json scripts/tradewise-research-upstream-smoke.ts",
    "smoke:tradewise:review:direct": "npx --yes tsx --tsconfig tsconfig.json scripts/tradewise-review-direct-smoke.ts",
    "smoke:tradewise:review:route": "npx --yes tsx --tsconfig tsconfig.json scripts/tradewise-review-route-smoke.ts",
    "smoke:tradewise:research:route": "npx --yes tsx --tsconfig tsconfig.json scripts/tradewise-research-route-smoke.ts",
    "smoke:tradewise:route:all": "node scripts/tradewise-route-all-smoke.mjs",
    "smoke:benyuan:test-packs": "node scripts/benyuan-test-pack-audit.mjs",
    "smoke:benyuan:golden": "node scripts/benyuan-golden-audit.mjs",
    "smoke:benyuan:benchmark": "node scripts/benyuan-pack-benchmark.mjs",
    "smoke:tradewise:visual-baseline": "node scripts/tradewise-visual-baseline-smoke.mjs",
    "lane:worktrees": "bash scripts/parallel-worktree.sh ensure all",
    "lane:worktrees:status": "bash scripts/parallel-worktree.sh status all",
    "lane:bootstrap": "PARALLEL_BOOTSTRAP_START=0 bash scripts/parallel-bootstrap.sh all",
    "lane:bootstrap:start": "bash scripts/parallel-bootstrap.sh all",
    "lane:bootstrap:no-start": "PARALLEL_BOOTSTRAP_START=0 bash scripts/parallel-bootstrap.sh all",
    "lane:stop": "bash scripts/parallel-lane.sh stop benyuan && bash scripts/parallel-lane.sh stop tradewise",
    "lane:status": "bash scripts/parallel-lane.sh status all",
    "lane:benyuan:start": "bash scripts/parallel-lane.sh start benyuan",
    "lane:benyuan:stop": "bash scripts/parallel-lane.sh stop benyuan",
    "lane:benyuan:tail": "bash scripts/parallel-lane.sh tail benyuan",
    "lane:benyuan:prompt": "bash scripts/parallel-lane.sh prompt benyuan",
    "lane:tradewise:start": "bash scripts/parallel-lane.sh start tradewise",
    "lane:tradewise:start:crs": "TRADEWISE_PROFILE=crs bash scripts/parallel-lane.sh start tradewise",
    "lane:tradewise:start:remote": "TRADEWISE_PROFILE=remote bash scripts/parallel-lane.sh start tradewise",
    "lane:tradewise:stop": "bash scripts/parallel-lane.sh stop tradewise",
    "lane:tradewise:tail": "bash scripts/parallel-lane.sh tail tradewise",
    "lane:tradewise:prompt": "bash scripts/parallel-lane.sh prompt tradewise",
    "smoke:tradewise:review:schema-fixture": "npx --yes tsx --tsconfig tsconfig.json scripts/tradewise-review-schema-fixture-smoke.ts",
    "dev:tradewise:crs:lan": "TRADEWISE_REVIEW_PROVIDER=crs next dev --hostname 0.0.0.0 --port 3201",
    "dev:tradewise:mock:lan": "next dev --hostname 0.0.0.0 --port 3201"
  },
  "dependencies": {
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@tailwindcss/postcss": "4.1.17",
    "@types/node": "24.10.1",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "^16.2.4",
    "tailwindcss": "4.1.17",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
