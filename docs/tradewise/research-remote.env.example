# 复制为你自己的 env 文件，再通过
# TRADEWISE_REMOTE_ENV_FILE=/abs/path/to/file npm run dev:tradewise:remote
# 来启动。

TRADEWISE_RESEARCH_REMOTE_URL=http://127.0.0.1:9000/feed
TRADEWISE_RESEARCH_REMOTE_AUTH_TOKEN=replace-me
TRADEWISE_RESEARCH_REMOTE_HEADERS={"x-tradewise-trace":"remote-dev"}

# 如果上游不是 market/limit，可覆盖下面这组参数
TRADEWISE_RESEARCH_REMOTE_MARKET_PARAM=market
TRADEWISE_RESEARCH_REMOTE_LIMIT_PARAM=limit
TRADEWISE_RESEARCH_REMOTE_MARKET_VALUE_A_STOCK=a_stock
TRADEWISE_RESEARCH_REMOTE_MARKET_VALUE_US_STOCK=us_stock
