# 复制到 mobile/tradewise_ai/.internal-beta.env，或通过
# TRADEWISE_INTERNAL_BETA_ENV_FILE=/abs/path/to/file
# 让 run_internal_beta.sh / build_internal_beta.sh / live_acceptance_smoke.sh / collect_internal_beta_artifacts.sh 自动加载。

# 正式内测请改成可从真机访问的 TradeWise API 地址；不要保留 localhost/127.0.0.1/10.0.2.2。
TRADEWISE_API_BASE_URL=https://tradewise.example.com/api/tradewise

# 可选：覆盖本地无锁 route 预检地址。
TRADEWISE_WEB_PORT=3201
TRADEWISE_PREFLIGHT_SMOKE_MODE=route

# 可选：如需放宽 review 超时，可在 beta 环境文件里覆盖。
TRADEWISE_REVIEW_TIMEOUT_MS=30000
